{
  "name": "weekly-task-board",
  "version": "1.9.0",
  "description": "効率的なタスク管理のためのウィークリータスクボード",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:vite": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:outlook": "jest --testPathPattern=outlook",
    "test:google": "jest --testPathPattern=google",
    "test:calendar": "jest --testPathPattern='(outlook|google)'",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "task",
    "management",
    "weekly",
    "board",
    "productivity"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/y-maeda1116/Weekly-Task-Board.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "jsdom": "^29.1.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^0.34.0"
  }
}
