# ==========================================
# カレンダー連携認証情報設定
# ==========================================
# このファイルを .env としてコピーして、実際の認証情報を設定してください
# .env ファイルは Git にコミットされません

# ==========================================
# Google Calendar API 設定
# ==========================================
# Google Cloud Console から取得した認証情報
# 設定手順: docs/GOOGLE_CALENDAR_SETUP.md を参照してください
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/google-callback

# ==========================================
# Outlook Calendar API 設定 (Azure AD)
# ==========================================
# Azure Portal から取得した認証情報
# 設定手順: docs/OUTLOOK_CALENDAR_SETUP.md を参照してください (または README.md)
AZURE_CLIENT_ID=your-azure-client-id
AZURE_REDIRECT_URI=http://localhost:3000/outlook-callback
AZURE_AUTHORITY=https://login.microsoftonline.com/common/oauth2/v2.0

# ==========================================
# 開発環境設定
# ==========================================
# 開発サーバーのポート
DEV_SERVER_PORT=3000

# API 基底URL (必要に応じて変更)
API_BASE_URL=http://localhost:3000
